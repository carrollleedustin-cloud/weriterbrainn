{
  "name": "personal-ai-brain-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.17.0"
  },
  "prisma": {
    "schema": "src/infrastructure/db/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/app/http/server.ts",
    "dev:workers": "tsx watch src/app/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app/http/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'add eslint later'",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@prisma/client": "^5.15.0",
    "bullmq": "^5.7.8",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.2",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "openai": "^4.52.7",
    "pg": "^8.11.3",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "zod": "^3.22.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "prisma": "^5.15.0",
    "tsx": "^4.7.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
