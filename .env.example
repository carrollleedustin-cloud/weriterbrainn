# WeriterBrainn – Environment Variables
# Copy to .env and fill in values

# Required for AI features
OPENAI_API_KEY=sk-your-openai-key

# PostgreSQL with pgvector (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/weriterbrainn

# Optional: API key for backend auth
# API_KEY=your-secret-api-key
